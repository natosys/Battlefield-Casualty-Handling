  "scenarios": {
    "moderate_intensity": {
      "label": "Moderate Intensity — Falklands 1982 (Operation CORPORATE, British Task Force, South Atlantic)",
      "source": "Payne (1983); Jolly (2018); Blood, Zouris & Rotblatt (1998) FORECAS Table A.8",
      "notes": "Named for FORECAS's own battle-intensity framing (NONE/LOW/MODERATE/HEAVY/INTENSE) rather than a specific historical engagement, since FORECAS's casualty-rate model selects a distribution family by battle intensity, not by named conflict — Falklands is the moderate-intensity calibration exemplar this project has validated, per FORECAS's own text pairing lognormal-distributed WIA/KIA incidence with 'a moderate battle intensity scenario'. Casualty generation rates (generators), priority distribution, DNBI composition, surgery/evacuation probabilities, and transport time distributions are NOT overridden here because the base env_data.json values are already Falklands-sourced (FORECAS Table A.8 combat WIA/KIA rates; FORECAS pp22-23 and Izaguirre et al. (2025) for DNBI composition) rather than generic or modern-era artifacts. Only the DOW ceiling and treatment-efficacy factors are overridden: the base values for those two groups are OIF/OEF-era (TCCC, damage control resuscitation/surgery), which did not exist as doctrine in 1982, so applying them to this scenario would misattribute modern treatment technique for the low historical DOW rate. See README 'Scenario Profiles' section.",
      "vars": [
        {
          "elm": "dow",
          "actys": [
            {
              "acty": "params",
              "vals": [
                { "var": "p1_p_base", "val": 0.001 },
                { "var": "p1_p_max",  "val": 0.0089 },
                { "var": "p1_k",      "val": 0.04  },
                { "var": "p1_t_mid",  "val": 120   },
                { "var": "p2_p_base", "val": 0.0005 },
                { "var": "p2_p_max",  "val": 0.0074 },
                { "var": "p2_k",      "val": 0.025 },
                { "var": "p2_t_mid",  "val": 180   },
                { "var": "p3_flat",   "val": 0.001 }
              ]
            },
            {
              "acty": "treatment_efficacy",
              "vals": [
                { "var": "r1_tccc_factor",   "val": 1.0  },
                { "var": "r2b_resus_factor", "val": 0.90 },
                { "var": "r2b_dcs_factor",   "val": 0.55 },
                { "var": "r2e_resus_factor", "val": 0.90 },
                { "var": "r2e_dcs1_factor",  "val": 0.55 },
                { "var": "r2e_dcs2_factor",  "val": 0.80 }
              ]
            }
          ]
        }
      ]
    },
    "high_intensity": {
      "label": "High Intensity — Okinawa (peer-conflict, mass casualty production)",
      "source": "Blood, Zouris & Rotblatt (1998), FORECAS Table A.7 (combat troop WIA, exponentially-approximated) and Table A.9 (combat troop KIA, exponentially-approximated)",
      "notes": "SKELETON PROFILE (Issue #54): demonstrates that the scenario mechanism generalises beyond moderate_intensity, and that the underlying distribution family (not just its parameters) is itself scenario-specific per FORECAS's own methodology. Named for FORECAS's own battle-intensity framing rather than a specific historical engagement; Okinawa is the high-intensity calibration exemplar. It is not a fully validated second scenario. FORECAS reports that INFANTRY (direct combat) troop WIA and KIA incidence in high-intensity battles is best approximated by a single-parameter exponential distribution, W ~ exponential(mean); FORECAS separately keeps its own 'SUPPORT' category (intra-divisional combat support: tank, artillery, light-armoured infantry, combat engineer) lognormal at all intensities, and reserves the fully lognormal, non-autocorrelated treatment for its distinct 'SERVICE SUPPORT' category (extra-divisional sustainment: FSSG, SRIG). This simulation models a single brigade (division and below); it has no extra-divisional 'service support' population, and this project's 'support' population group represents an organic brigade element exposed to the same battle risk as the 'combat' population, not FORECAS's rear-area service support troops. Both generators.wia_cbt/kia_cbt AND generators.wia_spt/kia_spt are therefore overridden with distribution=exponential, using Table A.7's Expon(6.86) (historical data mean 6.86, SD 6.65) and Table A.9's Expon(1.63) (historical mean 1.63, SD 1.73) — sd_daily is retained for reference but unused by generate_exp_arrivals(), a single-parameter distribution. DOW ceiling, treatment efficacy factors, priority distribution, DNBI composition, and transport time distributions are NOT sourced for Okinawa in this issue and are inherited from the base (Falklands-calibrated) configuration as a known placeholder — see README Limitations. Issue #10 (comparative scenario runner) owns extending this to a fully parameterised scenario. A companion Vietnam-calibrated profile was considered but dropped: FORECAS's Appendix A has no standalone Vietnam combat-troop WIA/KIA distribution table (Table A.5 is Vietnam combat-troop DNBI only), so no genuinely FORECAS-sourced Vietnam WIA/KIA parameters exist in this document.",
      "vars": [
        {
          "elm": "generators",
          "actys": [
            {
              "acty": "wia_cbt",
              "vals": [
                { "var": "mean_daily", "val": 6.86 },
                { "var": "sd_daily", "val": 6.65 },
                { "var": "distribution", "val": "exponential" }
              ]
            },
            {
              "acty": "kia_cbt",
              "vals": [
                { "var": "mean_daily", "val": 1.63 },
                { "var": "sd_daily", "val": 1.73 },
                { "var": "distribution", "val": "exponential" }
              ]
            },
            {
              "acty": "wia_spt",
              "vals": [
                { "var": "mean_daily", "val": 6.86 },
                { "var": "sd_daily", "val": 6.65 },
                { "var": "distribution", "val": "exponential" }
              ]
            },
            {
              "acty": "kia_spt",
              "vals": [
                { "var": "mean_daily", "val": 1.63 },
                { "var": "sd_daily", "val": 1.73 },
                { "var": "distribution", "val": "exponential" }
              ]
            }
          ]
        }
      ]
    }
  }

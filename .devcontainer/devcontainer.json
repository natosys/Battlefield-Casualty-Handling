{
  "name": "Battlefield Casualty Handling — R/simmer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "overrideCommand": false,
  "forwardPorts": [8787],
  "containerEnv": {
    "DISABLE_AUTH": "true"
  },
  "workspaceFolder": "/home/rstudio/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/rstudio/workspace,type=bind,consistency=cached",
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r"
      ],
      "settings": {
        "r.rterm.linux": "/usr/bin/R",
        "r.bracketedPaste": true
      }
    }
  },
  "postCreateCommand": "Rscript -e \"if (!requireNamespace('languageserver', quietly = TRUE)) install.packages('languageserver', repos = 'https://cloud.r-project.org')\"",
  "postStartCommand": "echo 'RStudio Server available at http://localhost:8787 | Working directory: /home/rstudio/workspace'"
}
